# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Optional Postgres connection. If omitted, server runs in-memory mode.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agilesync

# OpenAI API key for AI features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Client
VITE_API_BASE_URL=/api
